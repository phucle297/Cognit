{
  "name": "cognit",
  "version": "0.0.0",
  "private": true,
  "description": "Git for AI cognition. Local-first persistent decision and knowledge layer for AI-assisted engineering.",
  "type": "module",
  "scripts": {
    "preinstall": "pkill -f 'turbo.*daemon' >/dev/null 2>&1 || true",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "turbo": "2.3.3",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
