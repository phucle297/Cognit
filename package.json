{
  "name": "cognit",
  "version": "0.0.0",
  "private": true,
  "description": "Git for AI cognition. Local-first persistent decision and knowledge layer for AI-assisted engineering.",
  "type": "module",
  "scripts": {
    "preinstall": "pkill -f 'turbo.*daemon' >/dev/null 2>&1 || true",
    "build": "turbo run build",
    "dev": "turbo watch dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260618.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "turbo": "^2.9.18",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
