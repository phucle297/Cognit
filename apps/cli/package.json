    "commander": "^15.0.0",
    "effect": "3.21.3",
    "tar": "^7.5.16",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "better-sqlite3": "^12.11.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
