{
  "name": "@cognit/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "cognit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup && pnpm run copy-migrations",
    "prepare": "pnpm run build",
    "copy-migrations": "rm -rf dist/migrations && cp -R ../../packages/db/src/schema/migrations dist/migrations",
    "typecheck": "tsgo --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@cognit/agent": "workspace:*",
    "@cognit/core": "workspace:*",
    "@cognit/db": "workspace:*",
    "@cognit/llm": "workspace:*",
    "@cognit/verification": "workspace:*",
    "@cognit/wrap": "workspace:*",
    "@ai-sdk/anthropic": "^2.0.83",
    "@ai-sdk/gateway": "^3.0.0",
    "@ai-sdk/google": "^2.0.76",
    "@ai-sdk/openai": "^2.0.108",
    "ai": "^6.0.208",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "effect": "3.21.3",
    "ollama-ai-provider-v2": "^2.0.0",
    "tar": "^7.5.16",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "better-sqlite3": "^12.11.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
