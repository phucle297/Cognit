{
  "name": "@cognit/cli",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "cognit": "./src/index.ts"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@cognit/core": "workspace:*",
    "@cognit/db": "workspace:*",
    "chokidar": "^4.0.0",
    "commander": "12.1.0",
    "effect": "3.21.3",
    "yaml": "2.6.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
